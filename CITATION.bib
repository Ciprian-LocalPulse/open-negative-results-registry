% CITATION.bib
%
% BibTeX companion to CITATION.cff, for researchers whose citation
% workflow is LaTeX/BibTeX-based rather than CFF-tooling-based.
% GitHub's automatic "Cite this repository" button reads CITATION.cff;
% this file exists for the significant share of biomedical and
% computational researchers who cite via .bib files directly.
%
% Keep the two files in sync manually when metadata changes (title,
% version, date-released, DOI once Zenodo archiving is activated --
% see .zenodo.json).

@misc{darkdatamedicine2026,
  author       = {Plesca, Ciprian Stefan},
  title        = {{Dark Data Medicine: The Open Negative Results Registry}},
  year         = {2026},
  publisher    = {GitHub},
  howpublished = {\url{https://github.com/Ciprian-LocalPulse/open-negative-results-registry}},
  version      = {1.0.0},
  note         = {Open-source registry and JSON schema for negative and
                   null results in biomedical research. Code: MIT
                   license. Data: CC0-1.0 / CC-BY-4.0, per entry. DOI
                   pending Zenodo archival -- see .zenodo.json.},
  keywords     = {negative results, publication bias, open science,
                   dark data, clinical trials, biomedical research,
                   reproducibility, meta-analysis},
}

% If citing a specific dataset snapshot rather than the codebase as a
% whole, prefer the Zenodo-minted DOI once available (.zenodo.json)
% and cite as @dataset instead of @misc, e.g.:
%
% @dataset{darkdatamedicine_v1_0_0,
%   author    = {Plesca, Ciprian Stefan},
%   title     = {{Dark Data Medicine: The Open Negative Results Registry (v1.0.0)}},
%   year      = {2026},
%   publisher = {Zenodo},
%   version   = {1.0.0},
%   doi       = {10.5281/zenodo.XXXXXXX},
%   url       = {https://doi.org/10.5281/zenodo.XXXXXXX}
% }
