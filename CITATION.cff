title: "Dark Data Medicine: The Open Negative Results Registry"
type: dataset
authors:
  - family-names: "Plesca"
    given-names: "Ciprian Stefan"
    orcid: "https://orcid.org/0009-0006-1340-0232"
repository-code: "https://github.com/Ciprian-LocalPulse/open-negative-results-registry"
